# Copy this file to `.env` and fill in your key.
#     cp .env.example .env
#
# NOTE: `.env.example` is the shareable template and is meant to be committed.
# Never put a real key in this file — put it in `.env`, which is gitignored.

# --- Required (well, almost) ------------------------------------------------------------
# Get a free key at https://console.groq.com/keys
# Without it Twin still runs: routing falls back to rules and answers to templates.
# Every number stays identical either way, because the numbers never come from the LLM.
GROQ_API_KEY=

# The model that writes the answers. Verify the current id in the Groq console —
# model names get retired and this is the single most likely thing to break.
GROQ_MODEL=llama-3.3-70b-versatile

# --- Optional ---------------------------------------------------------------------------
# If set, Twin embeds the knowledge base with OpenAI's text-embedding-3-small.
# If not, it uses the local sentence-transformers model instead — no key required.
# Leave this blank unless you have a reason not to.
OPENAI_API_KEY=
